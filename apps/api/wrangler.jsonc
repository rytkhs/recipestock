{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "recipestock",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-25",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "../web/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "r2_buckets": [
    {
      "binding": "RECIPE_IMAGES",
      "bucket_name": "recipestock-images-dev",
      "remote": true
    }
  ],
  "vars": {
    "APP_ENV": "development",
    "IMPORT_TIMEOUT_MS": "30000",
    "R2_BUCKET_NAME": "recipestock-images-dev",
    "AI_GATEWAY_NAME": "recipestock",
    "AI_TEXT_MODEL": "openai/gpt-5.2",
    "AI_VISION_MODEL": "openai/gpt-5.2"
  }
}
